# Database
DATABASE_URL=postgresql+asyncpg://pawly:pawly_pass@postgres:5432/pawly

# Redis
REDIS_URL=redis://redis:6379

# Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_PROXY_URL=
ADMIN_TELEGRAM_IDS=

# Google / Gemini
GOOGLE_API_KEY=your-google-cloud-api-key-here

# Google Maps (optional)
GOOGLE_MAPS_API_KEY=

# App
NODE_ENV=production
PORT=8000
LOG_LEVEL=info
WEBHOOK_HOST=api.pawly.app
PROMPT_HOT_RELOAD=false

# Gemini models
MAIN_MODEL=gemini-2.5-flash
EXTRACTION_MODEL=gemini-2.5-flash

# Conversation settings
MAX_TURNS_IN_CONTEXT=5
MAX_MESSAGES_PER_MINUTE=30
